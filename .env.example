EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# docs/kakao-map.html을 GitHub Pages 등으로 호스팅한 URL.
# 카카오맵 JS SDK는 도메인 검증을 하기 때문에 WebView에 HTML을 직접 렌더링하지 않고
# 실제로 호스팅된 페이지를 불러오는 방식을 쓴다. 없으면 지도가 자동으로 기존
# placeholder(순수 View 핀)로 대체됨
EXPO_PUBLIC_KAKAO_MAP_PAGE_URL=https://your-username.github.io/your-repo/kakao-map.html

# 카카오 개발자 센터 > 내 애플리케이션 > 앱 키 > REST API 키.
# 수동 위치 검색(지오코딩)에 카카오 로컬 API(키워드 검색)를 쓰는 데 사용.
# 카카오맵 JS SDK와 달리 별도 활성화/결제수단 등록 없이 기본 무료 쿼터로 동작함.
EXPO_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key
